{
  "name": "peas-engine",
  "version": "0.2.0-kernel-rc.2",
  "private": true,
  "description": "Auditable deterministic event-processing and replay engine",
  "type": "module",
  "packageManager": "npm@12.0.0",
  "engines": {
    "node": "24.17.0",
    "npm": "12.0.0"
  },
  "scripts": {
    "verify:runtime": "node scripts/verify-runtime.mjs",
    "verify:candidate": "node scripts/verify-candidate.mjs",
    "verify:fault-boundaries": "node scripts/verify-artifact-fault-boundaries.mjs",
    "verify:vault-runtime-root": "node scripts/verify-vault-runtime-root.mjs",
    "initialize:vault-runtime": "npm run build && node scripts/initialize-vault-runtime.mjs",
    "verify:vault-cross-device": "npm run build && node scripts/verify-vault-cross-device-rejection.mjs",
    "write:evidence": "node scripts/write-audit-evidence.mjs",
    "write:vault-platform-evidence": "node scripts/write-vault-platform-evidence.mjs",
    "reconcile:evidence": "node scripts/reconcile-audit-evidence.mjs",
    "package:rc-evidence": "node scripts/package-rc-evidence.mjs",
    "clean": "node scripts/clean-dist.mjs",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run clean && npm run build && node --test --test-concurrency=1 dist/test/**/*.test.js",
    "test:coverage": "npm run clean && npm run build && node scripts/run-test-coverage.mjs",
    "test:hard-kill": "npm run clean && npm run build && node scripts/run-artifact-hard-kill-matrix.mjs",
    "test:evidence-reconciliation": "node --test --test-reporter=spec dist/test/evidence-reconciliation.test.js",
    "test:mutation": "node scripts/mutation-gate.mjs",
    "test:scale": "npm run clean && npm run build && node --test dist/test/persistence-scale.test.js",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "check": "npm run verify:runtime && npm run verify:fault-boundaries && npm run format:check && npm run lint && npm run typecheck && npm run test:hard-kill && npm run test:coverage && npm run test:evidence-reconciliation && npm run test:mutation"
  },
  "dependencies": {
    "better-sqlite3": "12.11.1",
    "htmlparser2": "12.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.13.3",
    "fast-check": "4.9.0",
    "typescript": "7.0.2"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  }
}
