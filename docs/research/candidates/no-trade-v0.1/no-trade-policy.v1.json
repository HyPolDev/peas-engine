{
  "schemaVersion": 1,
  "policyVersion": "0.1",
  "status": "research-contract",
  "asOfDate": "2026-07-16",
  "scope": "US-listed earnings-event capture, research, shadow, and paper eligibility",
  "liveTradingAuthorized": false,
  "principles": {
    "captureFirst": true,
    "unknownFailsClosed": true,
    "tickerBlacklistIsPrimaryControl": false,
    "reasonCodesAreEffectiveDated": true,
    "noTradeSuppressesCapture": false
