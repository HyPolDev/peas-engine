    "maximumRegularSpreadBps": 50,
    "maximumExtendedSpreadBps": 100,
    "maximumTargetOrderFractionOfDisplayedCollarDepth": 0.1,
    "minimumConsensusContributors": 3,
    "minimumCleanSingleNameEvents": 12,
    "minimumPersistentWalkForwardFolds": 2,
    "thresholdStatus": "provisional-until-p5"
  },
