{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "files": {
    "includes": [
      "**",
      "!!.tmp-output-integrity",
      "!!dist",
      "!!node_modules",
      "!!coverage",
      "!!fixtures/sec/v1/bodies",
      "!!fixtures/fmp/v1/bodies",
      "!!fixtures/ir/nvidia/v1/bodies",
      "!!docs/research/candidates/no-trade-v0.1/no-trade-blueprint.html"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "complexity": {
        "useLiteralKeys": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  }
}
